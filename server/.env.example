# API key for the model provider used by /api/chat (OpenCode Go by default).
# deno.json passes --env-file, so copying this to .env is enough — no export needed.
MODEL_PROVIDER_API_KEY=

# Optional: override the default model id (used when a preset can't resolve one).
# MODEL_PROVIDER_MODEL=deepseek-v4-flash

# Optional: point at a prebuilt SQLite shared library to skip the first-run download.
# DENO_SQLITE_PATH=/path/to/sqlite3.dll