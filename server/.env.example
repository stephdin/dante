# OpenCode Go API key — required for /api/chat.
# Get one by subscribing to OpenCode Go at https://opencode.ai and copying your
# key from the OpenCode Zen console.
OPENCODE_API_KEY=

# Optional: override the default model used when a preset's model can't be
# resolved. Defaults to deepseek-v4-flash (cheap & fast).
# OPENCODE_MODEL=deepseek-v4-flash
